<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FirstQA – Docs & User Guide</title>
  <meta name="description" content="Everything you need to know about Ovi — your AI QA engineer. Commands, integrations, authentication, and FAQ.">
  <link rel="icon" type="image/svg+xml" href="/logo/firstqa-logo-mark.svg">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
<style>
:root{--bg:#0f1117;--bg2:#161a23;--bg3:#1c2130;--bg4:#242a38;--border:#262d3d;--border2:#313a4d;--text:#e8eaf0;--text2:#9ca3b8;--text3:#6b7280;--green:#10b981;--green2:#059669;--gg:rgba(16,185,129,.12);--amber:#f59e0b;--red:#ef4444;--font:'Inter',-apple-system,system-ui,sans-serif;--mono:'JetBrains Mono','SF Mono',monospace}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:var(--font);background:var(--bg);color:var(--text);-webkit-font-smoothing:antialiased;line-height:1.6}
a{color:var(--green);text-decoration:none}
a:hover{color:var(--green2)}
code{font-family:var(--mono);background:var(--gg);color:var(--green);padding:2px 8px;border-radius:6px;font-size:.88em}
.container{max-width:860px;margin:0 auto;padding:0 24px}

/* Nav */
.navbar{position:fixed;top:0;left:0;right:0;z-index:100;padding:12px 0;background:rgba(15,17,23,.9);backdrop-filter:blur(20px);border-bottom:1px solid var(--border)}
.navbar .container{display:flex;justify-content:space-between;align-items:center}
.logo img{height:28px}
.nav-links{display:flex;align-items:center;gap:24px}
.nav-links a{font-size:14px;color:var(--text2);transition:color .2s}
.nav-links a:hover{color:var(--text)}
.btn-nav{background:var(--green);color:#fff!important;padding:8px 18px;border-radius:8px;font-size:13px;font-weight:600;transition:background .2s}
.btn-nav:hover{background:var(--green2)!important}

/* Layout */
.docs-layout{display:grid;grid-template-columns:220px 1fr;gap:48px;padding-top:80px;align-items:start}
.docs-sidebar{position:sticky;top:96px;padding:24px 0}
.sidebar-section{margin-bottom:28px}
.sidebar-label{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:var(--text3);margin-bottom:10px}
.sidebar-links{display:flex;flex-direction:column;gap:4px}
.sidebar-links a{font-size:13px;color:var(--text2);padding:5px 10px;border-radius:6px;transition:all .2s}
.sidebar-links a:hover{color:var(--text);background:var(--bg2)}
.sidebar-links a.active{color:var(--green);background:var(--gg)}

/* Content */
.docs-content{padding:40px 0 80px}
.docs-content h1{font-size:28px;font-weight:700;margin-bottom:8px}
.docs-content .page-sub{font-size:15px;color:var(--text2);margin-bottom:48px;padding-bottom:32px;border-bottom:1px solid var(--border)}
.docs-content h2{font-size:20px;font-weight:700;margin:48px 0 16px;padding-top:8px}
.docs-content h3{font-size:15px;font-weight:600;margin:28px 0 10px;color:var(--text)}
.docs-content p{font-size:14px;color:var(--text2);margin-bottom:14px;line-height:1.8}
.docs-content ul,.docs-content ol{font-size:14px;color:var(--text2);padding-left:20px;margin-bottom:14px}
.docs-content li{margin-bottom:6px;line-height:1.8}
.docs-content strong{color:var(--text);font-weight:600}

/* Cards */
.info-card{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:20px 24px;margin-bottom:20px}
.info-card p{margin:0}

/* Table */
.docs-table{width:100%;border-collapse:collapse;margin-bottom:24px;font-size:13px}
.docs-table th{background:var(--bg2);color:var(--text);font-weight:600;padding:10px 14px;text-align:left;border:1px solid var(--border)}
.docs-table td{padding:10px 14px;border:1px solid var(--border);color:var(--text2);vertical-align:top}
.docs-table tr:nth-child(even) td{background:rgba(22,26,35,.5)}

/* Code block */
.code-block{background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:14px 18px;margin-bottom:16px;font-family:var(--mono);font-size:12px;color:var(--text2);overflow-x:auto;white-space:pre}

/* Score grid */
.score-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:24px}
.score-card{border-radius:8px;padding:14px 16px;border:1px solid}
.score-card .score-label{font-size:12px;font-weight:700;margin-bottom:4px}
.score-card p{font-size:13px;margin:0}
.score-go{background:rgba(16,185,129,.08);border-color:rgba(16,185,129,.3)}
.score-go .score-label{color:var(--green)}
.score-warn{background:rgba(245,158,11,.08);border-color:rgba(245,158,11,.3)}
.score-warn .score-label{color:var(--amber)}
.score-block{background:rgba(239,68,68,.08);border-color:rgba(239,68,68,.3)}
.score-block .score-label{color:var(--red)}

/* FAQ */
.faq-item{border-bottom:1px solid var(--border);padding:20px 0}
.faq-item:last-child{border-bottom:none}
.faq-q{font-size:15px;font-weight:600;color:var(--text);margin-bottom:10px}
.faq-a{font-size:14px;color:var(--text2);line-height:1.8}

/* CTA */
.docs-cta{background:var(--bg2);border:1px solid var(--border2);border-radius:14px;padding:36px;text-align:center;margin-top:60px}
.docs-cta h3{font-size:20px;font-weight:700;margin-bottom:10px}
.docs-cta p{font-size:14px;color:var(--text2);margin-bottom:24px}
.btn-primary{display:inline-flex;align-items:center;gap:8px;background:var(--green);color:#fff;font-size:14px;font-weight:600;padding:12px 22px;border-radius:9px;text-decoration:none;transition:background .2s;margin:4px}
.btn-primary:hover{background:var(--green2);color:#fff}
.btn-outline{display:inline-flex;align-items:center;gap:8px;background:transparent;color:var(--text2);font-size:14px;font-weight:500;padding:12px 22px;border-radius:9px;text-decoration:none;border:1px solid var(--border2);transition:all .2s;margin:4px}
.btn-outline:hover{color:var(--text);border-color:var(--green)}

@media(max-width:768px){
  .docs-layout{grid-template-columns:1fr}
  .docs-sidebar{display:none}
  .score-grid{grid-template-columns:1fr}
}
</style>
</head>
