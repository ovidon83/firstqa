            <!-- Step 1 -->
            <div class="j-step">
                <div class="j-num">1</div>
                <div class="j-card">
                    <h3>Install the GitHub App</h3>
                    <p>One click. Select your repos. No code changes, no CI config needed.</p>
                    <div class="j-tools">
                        <span><i class="fab fa-github"></i> GitHub</span>
                        <span><svg width="14" height="14" viewBox="0 0 100 100" fill="currentColor"><path d="M1.22541 61.5228c-.2225-.9485.90748-1.5459 1.59638-.857L39.3342 97.1782c.6889.6889.0915 1.8189-.857 1.5964C20.0515 94.4522 5.54779 79.9485 1.22541 61.5228ZM.00189135 46.8891c-.01764375.2833.08887215.5599.28957165.7606L52.3503 99.7085c.2007.2007.4773.3075.7606.2896 2.3692-.1476 4.6938-.46 6.9624-.9259.7645-.157 1.0301-1.0963.4782-1.6481L2.57595 39.4485c-.55186-.5519-1.49117-.2863-1.648174.4782-.465915 2.2686-.77832 4.5932-.92588465 6.9624ZM4.21093 29.7054c-.16649.3738-.08169.8106.20765 1.1l64.77602 64.776c.2894.2894.7262.3742 1.1.2077 1.7861-.7956 3.5171-1.6927 5.1855-2.684.5521-.328.6373-1.0867.1832-1.5407L8.43566 24.3367c-.45409-.4541-1.21271-.3689-1.54074.1832-.99132 1.6684-1.88843 3.3994-2.68399 5.1855ZM12.6587 18.074c-.3701-.3701-.393-.9637-.0443-1.3541C21.7795 6.45931 35.1114 0 49.9519 0 77.5927 0 100 22.4073 100 50.0481c0 14.8405-6.4593 28.1724-16.7199 37.3375-.3903.3487-.984.3258-1.3542-.0443L12.6587 18.074Z"/></svg> Linear</span>
                    </div>
                </div>
            </div>
            <div class="j-connector"><div class="j-line"></div></div>

            <!-- Step 2 — The full FirstQA offer -->
            <div class="j-step">
                <div class="j-num">2</div>
                <div class="j-card j-card-wide">
                    <h3>FirstQA Goes to Work</h3>
                    <p>Automatically on every PR — or triggered with <code>/qa</code>. Here&rsquo;s what kicks in:</p>
                    <div class="j-offer">
                        <div class="j-pillar j-pillar-ai">
                            <div class="j-pillar-header">
                                <div class="j-pillar-icon"><i class="fas fa-robot"></i></div>
                                <div>
                                    <strong>Ovi &mdash; AI QA Engineer</strong>
                                    <span>Automated &middot; 24/7 &middot; Every PR</span>
                                </div>
                            </div>
                            <div class="j-pillar-items">
                                <div class="j-item"><i class="fas fa-search"></i> PR &amp; ticket analysis — bugs, risks, edge cases</div>
                                <div class="j-item"><i class="fas fa-list-check"></i> Test recipe — prioritized scenarios with exact steps</div>
                                <div class="j-item"><i class="fas fa-play"></i> Browser test run — AI agent in real Chromium</div>
                                <div class="j-item"><i class="fas fa-file-code"></i> Playwright tests — spec files with accurate selectors</div>
                                <div class="j-item"><i class="fas fa-chart-bar"></i> Reports — pass/fail, screenshots, video in the PR</div>
                            </div>
                            <div class="j-pillar-trigger">
                                <code>/qa</code> <span class="j-or">or</span> auto on PR open/update
                            </div>
                        </div>
                        <div class="j-plus"><span>+</span></div>
                        <div class="j-pillar j-pillar-human">
                            <div class="j-pillar-header j-pillar-header-human">
                                <div class="j-pillar-icon j-pillar-icon-human"><i class="fas fa-user-check"></i></div>
                                <div>
                                    <strong>Human QA Engineers</strong>
                                    <span>On-demand &middot; Senior &middot; No hiring</span>
                                </div>
                            </div>
                            <div class="j-pillar-items j-pillar-items-human">
                                <div class="j-item"><i class="fas fa-check"></i> Exploratory testing before major releases</div>
                                <div class="j-item"><i class="fas fa-check"></i> Human judgment on complex flows &amp; UX</div>
                                <div class="j-item"><i class="fas fa-check"></i> Pre-launch audits &amp; go/no-go calls</div>
                                <div class="j-item"><i class="fas fa-check"></i> QA strategy &amp; process setup</div>
