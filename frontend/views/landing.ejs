<!-- ════════ WHAT OVI DOES ════════ -->
<section id="offering" class="offering">
    <div class="container">
        <div class="sh">
            <span class="sh-tag">What Ovi Does</span>
            <h2>QA is not a luxury anymore.</h2>
        </div>

        <div class="qa-flow">
            <div class="qa-step">
                <div class="qa-step-icon"><i class="fas fa-clipboard-list"></i></div>
                <div class="qa-step-body">
                    <h4>Ticket Analysis</h4>
                    <p>Reads requirements, flags gaps, and posts the QA questions a senior engineer would ask — before a line is written.</p>
                </div>
            </div>
            <div class="qa-arrow"><i class="fas fa-chevron-right"></i></div>
            <div class="qa-step">
                <div class="qa-step-icon"><i class="fas fa-code-pull-request"></i></div>
                <div class="qa-step-body">
                    <h4>PR Analysis</h4>
                    <p>Reviews every code diff for bugs, logic errors, edge cases, and UX risks before merge.</p>
                </div>
            </div>
            <div class="qa-arrow"><i class="fas fa-chevron-right"></i></div>
            <div class="qa-step">
                <div class="qa-step-icon"><i class="fas fa-globe"></i></div>
                <div class="qa-step-body">
                    <h4>Browser Testing</h4>
                    <p>Runs test scenarios in real Chromium. Screenshots and video evidence attached automatically.</p>
                </div>
            </div>
            <div class="qa-arrow"><i class="fas fa-chevron-right"></i></div>
            <div class="qa-step">
                <div class="qa-step-icon"><i class="fas fa-file-code"></i></div>
                <div class="qa-step-body">
                    <h4>Playwright Code</h4>
                    <p>Generates production-ready spec files with accurate selectors — ready to commit and run.</p>
                </div>
            </div>
            <div class="qa-arrow"><i class="fas fa-chevron-right"></i></div>
            <div class="qa-step">
                <div class="qa-step-icon"><i class="fas fa-chart-bar"></i></div>
                <div class="qa-step-body">
                    <h4>QA Report</h4>
                    <p>Posts a clear pass/fail report — bugs, results, and next steps — directly on the PR or ticket.</p>
                </div>
            </div>
        </div>

        <!-- Showcase — proof of each step, in e2e order -->
        <div class="showcase" style="margin-top:48px">
            <div class="showcase-tabs">
                <button class="stab active" data-tab="s-ticket"><i class="fas fa-clipboard-list"></i> Ticket Analysis</button>
                <button class="stab" data-tab="s-pr"><i class="fas fa-code-pull-request"></i> PR Analysis</button>
                <button class="stab" data-tab="s-browser"><i class="fas fa-globe"></i> Browser Testing</button>
                <button class="stab" data-tab="s-playwright"><i class="fas fa-file-code"></i> Playwright Code</button>
                <button class="stab" data-tab="s-report"><i class="fas fa-chart-bar"></i> Report</button>
            </div>
            <div class="showcase-panels">
                <div class="spanel active" id="s-ticket">
                    <img src="/images/landing/ticket-analysis.png" alt="Step 1 — Ovi reads the ticket, flags gaps, and posts QA questions before dev starts">
                </div>
                <div class="spanel" id="s-pr">
                    <img src="/images/landing/pr-analysis.png" alt="Step 2 — Ovi reviews the PR diff, finds bugs and edge cases before merge">
                </div>
                <div class="spanel" id="s-browser">
                    <img src="/images/landing/agentic-testing.png" alt="Step 3 — Ovi runs test scenarios in real Chromium with screenshots and video">
                </div>
                <div class="spanel" id="s-playwright">
                    <img src="/images/landing/playwright-code.png" alt="Step 4 — Ovi generates production-ready Playwright spec files">
                </div>
                <div class="spanel" id="s-report">
                    <img src="/images/landing/pr-review.png" alt="Step 5 — Ovi posts a clear pass/fail report directly on the PR or ticket">
                </div>
            </div>
        </div>

    </div>
</section>

