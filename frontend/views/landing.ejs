<style>
:root{--bg:#0f1117;--bg2:#161a23;--bg3:#1c2130;--bg4:#242a38;--border:#262d3d;--border2:#313a4d;--text:#e8eaf0;--text2:#9ca3b8;--text3:#6b7280;--green:#10b981;--green2:#059669;--gg:rgba(16,185,129,.12);--amber:#f59e0b;--red:#ef4444;--r:12px;--font:'Inter',-apple-system,system-ui,sans-serif;--mono:'JetBrains Mono','SF Mono',monospace}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:var(--font);background:var(--bg);color:var(--text);-webkit-font-smoothing:antialiased;line-height:1.6}
.container{max-width:1120px;margin:0 auto;padding:0 24px}
code{font-family:var(--mono);background:var(--gg);color:var(--green);padding:2px 8px;border-radius:6px;font-size:.88em;font-weight:500}
.gr{background:linear-gradient(135deg,#34d399,#10b981 50%,#059669);-webkit-background-clip:text;-webkit-text-fill-color:transparent}

/* Modal */
.modal-overlay{display:none;position:fixed;inset:0;z-index:200;background:rgba(0,0,0,.7);backdrop-filter:blur(8px);align-items:center;justify-content:center}
.modal-overlay.active{display:flex}
.modal-card{background:var(--bg3);border:1px solid var(--border2);border-radius:16px;padding:40px;max-width:460px;width:90%;text-align:center;position:relative;animation:mIn .2s ease-out}
@keyframes mIn{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:none}}
.modal-close{position:absolute;top:14px;right:18px;background:none;border:none;color:var(--text3);font-size:26px;cursor:pointer}.modal-close:hover{color:var(--text)}
.modal-card h2{font-size:24px;font-weight:700;margin-bottom:10px}
.modal-card>p{font-size:14px;color:var(--text2);margin-bottom:24px;line-height:1.6}
.modal-form{display:flex;gap:10px;margin-bottom:16px}
.modal-form input{flex:1;background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:12px 16px;font-size:14px;color:var(--text);font-family:var(--font);outline:none}
.modal-form input:focus{border-color:var(--green);box-shadow:0 0 0 3px var(--gg)}
.modal-form button{display:flex;align-items:center;gap:8px;background:var(--green);color:#fff;font-size:14px;font-weight:600;padding:12px 22px;border-radius:10px;border:none;cursor:pointer;white-space:nowrap;transition:all .2s}
.modal-form button:hover{background:var(--green2)}
.modal-msg{font-size:13px;min-height:18px}.modal-msg.success{color:var(--green)}.modal-msg.error{color:var(--red)}
.modal-sub{font-size:13px;color:var(--text3)}.modal-sub a{color:var(--green);text-decoration:none;font-weight:500}

/* Nav */
.navbar{position:fixed;top:0;left:0;right:0;z-index:100;padding:12px 0;background:rgba(15,17,23,.85);backdrop-filter:blur(20px);border-bottom:1px solid var(--border)}
.navbar .container{display:flex;justify-content:space-between;align-items:center}
.logo{display:flex;align-items:center;gap:10px;text-decoration:none;color:var(--text)}
.logo-img{display:block;height:32px;width:auto}
.logo-img-footer{height:26px}
.nav-links{display:flex;align-items:center;gap:22px}
.nav-links a{color:var(--text2);text-decoration:none;font-size:13px;font-weight:500;transition:color .2s}
.nav-links a:hover{color:var(--text)}
.btn-nav{background:var(--green)!important;color:#fff!important;padding:8px 18px;border-radius:8px;font-weight:600!important}
.btn-nav:hover{background:var(--green2)!important}
.mobile-menu-btn{display:none;background:none;border:none;color:var(--text);font-size:18px;cursor:pointer}

/* Hero */
.hero{padding:140px 0 80px;position:relative;overflow:hidden}
.hero-glow{position:absolute;top:0;left:50%;transform:translateX(-50%);width:900px;height:600px;background:radial-gradient(ellipse at 40% 40%,rgba(16,185,129,.1),transparent 65%);pointer-events:none}
.hero-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;position:relative;z-index:1}
.hero-badge{display:inline-flex;align-items:center;gap:8px;background:var(--bg3);border:1px solid var(--border2);padding:7px 16px;border-radius:100px;font-size:12px;font-weight:600;color:var(--green);margin-bottom:24px;text-transform:uppercase;letter-spacing:.5px}
.badge-dot{width:7px;height:7px;background:var(--green);border-radius:50%;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.hero h1{font-size:50px;font-weight:800;line-height:1.08;letter-spacing:-2px;margin-bottom:20px}
.hero-sub{font-size:16px;color:var(--text2);line-height:1.7;margin-bottom:32px;max-width:500px}
.hero-ctas{display:flex;gap:12px;margin-bottom:40px;flex-wrap:wrap}
.btn-primary{display:inline-flex;align-items:center;gap:8px;background:var(--green);color:#fff;font-size:14px;font-weight:600;padding:13px 24px;border-radius:10px;text-decoration:none;transition:all .2s;border:none;cursor:pointer}
.btn-primary:hover{background:var(--green2);transform:translateY(-1px);box-shadow:0 8px 24px var(--gg)}
.btn-partner{display:flex;flex-direction:column;align-items:center;gap:2px;padding:10px 20px;border-radius:10px;border:1px solid var(--border2);background:var(--bg2);text-decoration:none;color:var(--text);font-size:14px;font-weight:600;transition:all .2s}
.btn-partner:hover{border-color:var(--text3);background:var(--bg3)}
.partner-sub{font-size:11px;font-weight:500;color:var(--green)}
.hero-stats{display:flex;gap:28px;align-items:center}
.hs{display:flex;flex-direction:column;gap:3px}
.hs-val{font-size:22px;font-weight:700}
.hs-lbl{font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:.8px}
.hs-sep{width:1px;height:36px;background:var(--border)}

/* Terminal */
.terminal{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,.5)}
.t-bar{display:flex;align-items:center;gap:7px;padding:11px 16px;background:var(--bg3);border-bottom:1px solid var(--border)}
.dot{width:10px;height:10px;border-radius:50%}.dot.r{background:#ef4444}.dot.y{background:#eab308}.dot.g{background:#22c55e}
.t-title{margin-left:8px;font-size:12px;color:var(--text3);font-family:var(--mono)}
.t-body{padding:20px;font-family:var(--mono);font-size:12.5px;line-height:2}
.tl{opacity:0;animation:fadeUp .35s forwards;animation-delay:var(--d);display:flex;gap:8px;color:var(--text2);white-space:nowrap;overflow:hidden}
.ti{flex-shrink:0}
.tc{color:var(--green);font-weight:600}
.tl-indent{padding-left:20px;color:var(--text3)!important;font-size:12px!important}
.ts{color:#22c55e;font-weight:600}
.tw{color:var(--amber);font-weight:500}
@keyframes fadeUp{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:none}}

/* Problem */
.problem{padding:80px 0;border-top:1px solid var(--border)}
.sh{text-align:center;margin-bottom:48px}
.sh-tag{display:inline-block;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:2px;color:var(--green);margin-bottom:14px}
.sh h2{font-size:34px;font-weight:700;letter-spacing:-.8px;margin-bottom:10px}
.sh p{font-size:16px;color:var(--text2)}
.problem-card{max-width:800px;margin:0 auto;background:var(--bg2);border:1px solid var(--border);border-radius:16px;padding:36px}
.problem-pov{font-size:15px;color:var(--text2);line-height:1.8;margin-bottom:32px;border-left:3px solid var(--green);padding-left:18px}
.problem-pov strong{color:var(--text)}
/* Feedback columns */
.feedback-cols{display:grid;grid-template-columns:1fr auto 1fr;gap:0;margin-bottom:28px}
.fc-col{display:flex;flex-direction:column;gap:10px;padding:20px}
.fc-col-bad{background:rgba(239,68,68,.06);border:1px solid rgba(239,68,68,.15);border-radius:12px 0 0 12px}
.fc-col-good{background:rgba(16,185,129,.06);border:1px solid rgba(16,185,129,.15);border-radius:0 12px 12px 0}
.fc-header{display:flex;align-items:center;gap:8px;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;margin-bottom:4px}
.fc-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.fc-dot-bad{background:var(--red)}
.fc-dot-good{background:var(--green)}
.fc-item{font-size:13px;color:var(--text2);display:flex;align-items:flex-start;gap:8px;line-height:1.5}
.fc-emoji{font-size:14px;flex-shrink:0;margin-top:1px}
.fc-label{font-size:11px;color:var(--text3);margin-top:4px;font-style:italic}
.fc-divider{display:flex;align-items:center;justify-content:center;padding:0 12px;color:var(--text3);font-size:12px}
/* Runway bars */
.rework-cost{border-top:1px solid var(--border);padding-top:20px;display:flex;flex-direction:column;gap:12px}
.rc-title{font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.8px;color:var(--text3)}
.rc-row{display:flex;align-items:center;gap:14px}
.rc-label{font-size:12px;color:var(--text2);width:90px;flex-shrink:0;text-align:right}
.rc-track{flex:1;height:32px;display:flex;border-radius:8px;overflow:hidden;gap:2px}
.rc-seg{height:100%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;color:rgba(255,255,255,.9);white-space:nowrap;overflow:hidden;transition:width .6s ease}
.rc-seg-bad{background:linear-gradient(90deg,rgba(239,68,68,.75),rgba(239,68,68,.5))}
.rc-seg-build{background:linear-gradient(90deg,rgba(16,185,129,.5),rgba(16,185,129,.7))}
.rc-seg-thin span{display:none}
.rc-footnote{font-size:12px;color:var(--text3);font-style:italic;margin-top:4px;padding-left:104px}

/* Offering */
.offering{padding:100px 0;background:var(--bg2);border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
.offer-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px}
.offer-pillar{background:var(--bg);border:1px solid var(--border);border-radius:16px;padding:32px;display:flex;flex-direction:column}
.offer-ai{border-color:rgba(16,185,129,.2)}
.offer-human{border-color:rgba(245,158,11,.15)}
.op-header{display:flex;gap:16px;align-items:center;margin-bottom:24px;padding-bottom:20px;border-bottom:1px solid var(--border)}
.op-icon{width:48px;height:48px;background:var(--gg);border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.op-icon i{font-size:20px;color:var(--green)}
.op-icon-human{background:rgba(245,158,11,.1)}.op-icon-human i{color:var(--amber)}
.op-header h3{font-size:18px;font-weight:700;margin-bottom:2px}
.op-sub{font-size:13px;color:var(--text3)}
.op-list{list-style:none;display:flex;flex-direction:column;gap:14px;flex:1}
.op-list li{display:flex;gap:12px;align-items:flex-start}
.op-list li>i{width:32px;height:32px;background:var(--gg);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:13px;color:var(--green);flex-shrink:0;margin-top:2px}
.op-list-human li>i{background:rgba(245,158,11,.1);color:var(--amber)}
.op-list li div{display:flex;flex-direction:column;gap:1px}
.op-list li strong{font-size:14px;font-weight:600}
.op-list li span{font-size:13px;color:var(--text3);line-height:1.4}
.op-trigger{padding-top:0;font-size:13px;color:var(--text2)}
.op-trigger-label{font-weight:600;color:var(--text3);text-transform:uppercase;font-size:11px;letter-spacing:.5px;margin-right:6px}
.op-or{color:var(--text3);font-style:italic;margin:0 4px}
/* QA Flow */
.qa-flow{display:flex;align-items:flex-start;gap:0;margin-bottom:0}
.qa-step{flex:1;display:flex;flex-direction:column;align-items:center;text-align:center;padding:0 6px}
.qa-step-num{width:22px;height:22px;background:var(--green);color:#fff;border-radius:50%;font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center;margin-bottom:10px;flex-shrink:0}
.qa-step-icon{width:48px;height:48px;background:var(--gg);border:1px solid rgba(16,185,129,.2);border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:12px;font-size:18px;color:var(--green);flex-shrink:0}
.qa-step-body h4{font-size:13px;font-weight:700;margin-bottom:5px;color:var(--text)}
.qa-step-body p{font-size:11.5px;color:var(--text3);line-height:1.55}
.qa-arrow{flex-shrink:0;width:28px;display:flex;align-items:center;justify-content:center;color:var(--border2);font-size:12px;padding-top:58px}
.btn-human{display:inline-flex;align-items:center;gap:10px;margin-top:20px;background:transparent;border:1px solid rgba(245,158,11,.3);color:var(--amber);font-size:14px;font-weight:600;padding:12px 22px;border-radius:10px;text-decoration:none;transition:all .2s}
.btn-human:hover{background:rgba(245,158,11,.08);border-color:var(--amber);transform:translateY(-1px)}

/* In Action (Screenshots) */
.in-action{padding:100px 0;border-bottom:1px solid var(--border)}
.showcase{max-width:860px;margin:0 auto}
.showcase-tabs{display:flex;gap:4px;margin-bottom:20px;background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:4px;overflow-x:auto}
.stab{flex:1;background:none;border:none;color:var(--text3);font-size:13px;font-weight:500;padding:10px 16px;border-radius:8px;cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:8px;justify-content:center;white-space:nowrap;font-family:var(--font)}
.stab:hover{color:var(--text2)}
.stab.active{background:var(--bg3);color:var(--text);font-weight:600;box-shadow:0 1px 4px rgba(0,0,0,.2)}
.stab i{font-size:12px}
.spanel{display:none;border-radius:var(--r);overflow:hidden;border:1px solid var(--border);background:var(--bg2)}
.spanel.active{display:block}
.spanel img{width:100%;display:block}


/* How It Works — Journey */
.how-section{padding:100px 0;background:var(--bg2);border-bottom:1px solid var(--border)}
.journey{max-width:780px;margin:0 auto;display:flex;flex-direction:column;align-items:center}
.j-step{display:flex;gap:20px;align-items:flex-start;width:100%}
.j-num{width:40px;height:40px;background:var(--green);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:700;color:#fff;flex-shrink:0;margin-top:4px}
.j-card{flex:1;background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);padding:28px 32px}
.j-card h3{font-size:18px;font-weight:600;margin-bottom:6px}
.j-card p{font-size:14px;color:var(--text2);line-height:1.6}
.j-card code{background:rgba(16,185,129,.12);color:var(--green);padding:2px 8px;border-radius:4px;font-size:13px;font-family:var(--mono)}
.j-card-wide{padding:32px}
.j-tools{display:flex;gap:8px;margin-top:14px;flex-wrap:wrap}
.j-tools span{display:inline-flex;align-items:center;gap:5px;background:var(--bg2);border:1px solid var(--border);padding:5px 12px;border-radius:8px;font-size:12px;color:var(--text2)}
.j-connector{display:flex;justify-content:flex-start;padding-left:19px}
.j-line{width:2px;height:32px;background:var(--border)}

/* Journey — offer pillars */
.j-offer{display:grid;grid-template-columns:1fr auto 1fr;gap:0;align-items:stretch;margin-top:20px}
.j-plus{display:flex;align-items:center;justify-content:center;padding:0 18px}
.j-plus span{width:36px;height:36px;border-radius:50%;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:600;color:var(--text3);background:var(--bg2)}
.j-pillar{border:1px solid var(--border);border-radius:var(--r);padding:24px;background:var(--bg2)}
.j-pillar-ai{border-color:rgba(16,185,129,.2);background:linear-gradient(145deg,rgba(16,185,129,.05),var(--bg2) 50%)}
.j-pillar-human{border-color:rgba(245,158,11,.15);background:linear-gradient(145deg,rgba(245,158,11,.04),var(--bg2) 50%)}
.j-pillar-header{display:flex;gap:12px;align-items:center;margin-bottom:16px}
.j-pillar-icon{width:34px;height:34px;background:var(--green);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:14px;color:#fff;flex-shrink:0}
.j-pillar-icon-human{background:var(--amber)}
.j-pillar-header strong{font-size:14px;display:block;margin-bottom:2px}
.j-pillar-header span{font-size:12px;color:var(--text3);display:block}
.j-pillar-header-human strong{color:var(--amber)}
.j-pillar-items{display:flex;flex-direction:column;gap:8px}
.j-pillar-items-human .j-item i{color:var(--amber)}
.j-item{font-size:13px;color:var(--text2);display:flex;align-items:center;gap:8px}
.j-item i{color:var(--green);font-size:11px;width:16px;text-align:center;flex-shrink:0}
.j-pillar-trigger{margin-top:16px;padding-top:14px;border-top:1px solid var(--border);font-size:12px;color:var(--text3)}
.j-pillar-trigger code{background:rgba(16,185,129,.12);color:var(--green);padding:2px 7px;border-radius:4px;font-family:var(--mono);font-size:12px}
.j-or{color:var(--text3);margin:0 4px}
.j-human-cta{display:inline-flex;align-items:center;gap:6px;margin-top:16px;padding:8px 18px;font-size:13px;font-weight:500;color:var(--amber);border:1px solid rgba(245,158,11,.25);border-radius:8px;text-decoration:none;transition:all .2s}
.j-human-cta:hover{background:rgba(245,158,11,.08);border-color:var(--amber)}

/* CTA */
.cta-section{padding:120px 0;text-align:center;position:relative}
.cta-section::before{content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:600px;height:300px;background:radial-gradient(ellipse,var(--gg),transparent 65%);pointer-events:none}
.cta-section .container{position:relative;z-index:1}
.cta-section h2{font-size:34px;font-weight:700;letter-spacing:-.5px;margin-bottom:14px;line-height:1.2}
.cta-section p{font-size:16px;color:var(--text2);margin-bottom:32px}
.cta-btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}
.btn-secondary{display:inline-flex;align-items:center;gap:8px;background:transparent;color:var(--text2);font-size:14px;font-weight:500;padding:13px 24px;border-radius:10px;text-decoration:none;border:1px solid var(--border);transition:all .2s}
.btn-secondary:hover{color:var(--text);border-color:var(--text3);background:var(--bg2)}
.btn-partner{color:var(--text);border-color:var(--border2);font-weight:600}
.btn-partner:hover{border-color:var(--green);color:var(--green);background:var(--gg)}

/* Footer */
.footer{padding:52px 0 28px;border-top:1px solid var(--border)}
.footer-top{display:grid;grid-template-columns:1fr auto;gap:64px;margin-bottom:36px}
.footer-brand p{font-size:13px;color:var(--text3);margin-top:12px}
.footer-cols{display:flex;gap:56px}
.footer-cols h4{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:1.5px;color:var(--text2);margin-bottom:14px}
.footer-cols a{display:block;font-size:13px;color:var(--text3);text-decoration:none;margin-bottom:10px;transition:color .2s}
.footer-cols a:hover{color:var(--text)}
.footer-bottom{padding-top:24px;border-top:1px solid var(--border)}
.footer-bottom p{font-size:12px;color:var(--text3)}

/* Offer — single full-width pillar */
.offer-single{display:flex;justify-content:center}
.offer-ai-full{width:100%;max-width:860px;margin:0 auto}
.op-list-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.op-list-grid li{gap:12px}

/* Human add-on strip */
.human-addon{display:flex;align-items:center;gap:16px;margin-top:28px;padding:18px 24px;background:var(--bg3);border:1px solid rgba(245,158,11,.15);border-radius:var(--r);max-width:860px;margin-left:auto;margin-right:auto;flex-wrap:wrap}
.human-addon i{color:var(--amber);font-size:18px;flex-shrink:0}
.human-addon span{flex:1;font-size:14px;color:var(--text2);min-width:200px}
.human-addon strong{color:var(--text)}
.human-addon a{display:inline-flex;align-items:center;gap:6px;color:var(--amber);font-size:13px;font-weight:600;text-decoration:none;white-space:nowrap;border:1px solid rgba(245,158,11,.25);padding:8px 16px;border-radius:8px;transition:all .2s}
.human-addon a:hover{background:rgba(245,158,11,.08);border-color:var(--amber)}

/* How it works — simple item list */
.j-items-list{display:flex;flex-direction:column;gap:10px;margin-top:18px}

/* Objections */
.objections{padding:100px 0;border-top:1px solid var(--border)}
.obj-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;max-width:960px;margin:0 auto}
.obj-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:28px}
.obj-q{font-size:14px;font-weight:600;color:var(--text);margin-bottom:12px;display:flex;align-items:center;gap:10px}
.obj-q i{color:var(--green);font-size:13px;flex-shrink:0}
.obj-card p{font-size:13px;color:var(--text2);line-height:1.7;margin:0}

/* Pricing */
.pricing-section{padding:100px 0;border-top:1px solid var(--border)}
.pricing-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;max-width:960px;margin:0 auto}
.pricing-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:32px;display:flex;flex-direction:column;gap:24px;position:relative}
.pricing-card-featured{border-color:rgba(16,185,129,.35);background:linear-gradient(145deg,rgba(16,185,129,.06),var(--bg2) 60%)}
.pricing-card-partner{border-color:rgba(245,158,11,.25);background:linear-gradient(145deg,rgba(245,158,11,.05),var(--bg2) 60%)}
.pc-coming-soon{position:absolute;top:16px;right:16px;background:var(--green);color:#fff;font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px;text-transform:uppercase;letter-spacing:.5px}
.pc-top{display:flex;flex-direction:column;gap:6px}
.pc-label{font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:1px;color:var(--text3)}
.pc-price{font-size:36px;font-weight:700;color:var(--text);line-height:1}
.pc-price span{font-size:16px;font-weight:400;color:var(--text3)}
.pc-sub{font-size:13px;color:var(--text3)}
.pc-features{list-style:none;display:flex;flex-direction:column;gap:10px;flex:1}
.pc-features li{display:flex;align-items:center;gap:10px;font-size:13px;color:var(--text2)}
.pc-features li i.fa-check{color:var(--green);font-size:11px;width:14px;flex-shrink:0}
.pc-features li i.fa-times{color:var(--text3);font-size:11px;width:14px;flex-shrink:0}
.pc-dim{opacity:.45}
.pc-btn{display:flex;align-items:center;justify-content:center;gap:8px;padding:12px;border-radius:10px;font-size:14px;font-weight:600;text-decoration:none;transition:all .2s;text-align:center}
.pc-btn-primary{background:var(--green);color:#fff}
.pc-btn-primary:hover{background:var(--green2)}
.pc-btn-ghost{background:transparent;color:var(--text2);border:1px solid var(--border2)}
.pc-btn-ghost:hover{color:var(--text);border-color:var(--text3);background:var(--bg3)}

/* Responsive */
@media(max-width:1024px){
    .hero-grid{grid-template-columns:1fr;text-align:center}
    .hero-left{display:flex;flex-direction:column;align-items:center}
    .hero-sub{max-width:560px}
    .hero-ctas{justify-content:center}
    .hero-stats{justify-content:center}
    .hero-right{order:-1;max-width:580px;margin:0 auto}
    .pricing-grid{grid-template-columns:1fr}
    .offer-grid{grid-template-columns:1fr}
    .op-list-grid{grid-template-columns:1fr}
    .obj-grid{grid-template-columns:1fr 1fr}
    .qa-flow{flex-wrap:wrap;gap:16px}
    .qa-step{flex:1;min-width:140px}
    .qa-arrow{display:none}
}
@media(max-width:768px){
    .nav-links{display:none}.mobile-menu-btn{display:block}
    .hero{padding:120px 0 60px}.hero h1{font-size:34px;letter-spacing:-1px}.hero h1 br{display:none}
    .hero-ctas{flex-direction:column;align-items:center}
    .hero-stats{flex-wrap:wrap;gap:20px}.hs-sep{display:none}
    .problem-card{padding:24px}
    .feedback-cols{grid-template-columns:1fr;gap:8px}
    .fc-col-bad{border-radius:12px}
    .fc-col-good{border-radius:12px}
    .fc-divider{transform:rotate(90deg)}
    .j-step{flex-direction:column;align-items:center}
    .j-card{width:100%}
    .j-connector{padding-left:0;justify-content:center}
    .qa-flow{flex-direction:column;gap:0}
    .qa-step{flex-direction:row;text-align:left;gap:14px;padding:16px 0;border-bottom:1px solid var(--border);width:100%}
    .qa-step:last-child{border-bottom:none}
    .qa-step-num{flex-shrink:0;margin-bottom:0}
    .qa-step-icon{flex-shrink:0;margin-bottom:0;width:40px;height:40px;font-size:16px}
    .showcase-tabs{overflow-x:auto;-webkit-overflow-scrolling:touch}
    .obj-grid{grid-template-columns:1fr}
    .human-addon{flex-direction:column;text-align:center}
    .footer-top{grid-template-columns:1fr;gap:32px}.footer-cols{gap:32px;flex-wrap:wrap}
    .cta-section h2{font-size:26px}
    .cta-btns{flex-direction:column;align-items:center}
    .btn-primary,.btn-secondary,.btn-partner{width:100%;max-width:280px;justify-content:center}
    .modal-form{flex-direction:column}
}
</style>

<script>
// Modal
const modal=document.getElementById('ea-modal'),modalClose=document.getElementById('modal-close');
document.querySelectorAll('[data-ea-trigger]').forEach(b=>{b.addEventListener('click',e=>{e.preventDefault();modal.classList.add('active');setTimeout(()=>modal.querySelector('input')?.focus(),100)})});
modalClose.addEventListener('click',()=>modal.classList.remove('active'));
modal.addEventListener('click',e=>{if(e.target===modal)modal.classList.remove('active')});
document.addEventListener('keydown',e=>{if(e.key==='Escape')modal.classList.remove('active')});

// Smooth scroll
document.querySelectorAll('a[href^="#"]').forEach(a=>{if(a.hasAttribute('data-ea-trigger'))return;a.addEventListener('click',function(e){e.preventDefault();const t=document.querySelector(this.getAttribute('href'));if(t)t.scrollIntoView({behavior:'smooth'})})});

// Ovi tag count
fetch('/api/stats/ovi-tag-count').then(r=>r.ok?r.json():null).then(d=>{const el=document.getElementById('ovi-tag-count');if(el&&d?.count)el.textContent=d.count}).catch(()=>{});

// Subscribe
document.getElementById('subscribe-form').addEventListener('submit',async function(e){
    e.preventDefault();const email=this.email.value,msg=document.getElementById('subscribe-message'),btn=this.querySelector('button');btn.disabled=true;
    try{const r=await fetch('/subscribe',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({email})});const d=await r.json();msg.textContent=d.success?'✓ You\'re on the list!':(d.error||'Something went wrong.');msg.className='modal-msg '+(d.success?'success':'error');if(d.success)this.email.value=''}catch{msg.textContent='Something went wrong.';msg.className='modal-msg error'}btn.disabled=false});

// Showcase tabs
document.querySelectorAll('.stab').forEach(tab=>{
    tab.addEventListener('click',()=>{
        document.querySelectorAll('.stab').forEach(t=>t.classList.remove('active'));
        document.querySelectorAll('.spanel').forEach(p=>p.classList.remove('active'));
        tab.classList.add('active');
        document.getElementById(tab.dataset.tab).classList.add('active');
    });
});
</script>

