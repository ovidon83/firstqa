<%- include('partials/header', { title: 'About FirstQA – Meet Ovi, Your AI QA Engineer' }) %>
<style>
body{background:#0f1117;color:#e8eaf0;font-family:'Inter',-apple-system,system-ui,sans-serif}
a{color:#10b981;text-decoration:none}
a:hover{color:#059669}
.container{max-width:1080px;margin:0 auto;padding:0 24px}

/* Hero */
.about-hero{padding:100px 0 80px;text-align:center}
.about-hero h1{font-size:48px;font-weight:700;margin-bottom:20px;letter-spacing:-.02em;line-height:1.15}
.about-hero h1 span{background:linear-gradient(135deg,#10b981,#059669);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.about-hero .lead{font-size:18px;color:#9ca3b8;max-width:600px;margin:0 auto;line-height:1.7}

/* Section */
.section{padding:72px 0}
.section-label{display:inline-block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:#10b981;margin-bottom:12px}
.section-title{font-size:32px;font-weight:700;margin-bottom:14px;letter-spacing:-.01em}
.section-sub{font-size:16px;color:#9ca3b8;max-width:560px;margin:0 auto 48px;line-height:1.7}
.text-center{text-align:center}

/* Mission */
.mission-card{background:#161a23;border:1px solid #262d3d;border-radius:16px;padding:48px;text-align:center;max-width:720px;margin:0 auto}
.mission-card h2{font-size:24px;font-weight:700;margin-bottom:16px}
.mission-card p{font-size:16px;color:#9ca3b8;line-height:1.8;margin:0}

/* Stats */
.stats-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;max-width:820px;margin:0 auto}
.stat-card{background:#161a23;border:1px solid #262d3d;border-radius:12px;padding:32px 24px;text-align:center}
.stat-number{display:block;font-size:52px;font-weight:700;background:linear-gradient(135deg,#10b981,#059669);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1;margin-bottom:10px}
.stat-label{font-size:14px;color:#9ca3b8;line-height:1.5}

/* Workflow */
.workflow-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.workflow-card{background:#161a23;border:1px solid #262d3d;border-radius:14px;padding:28px;transition:border-color .2s}
.workflow-card:hover{border-color:#313a4d}
.workflow-icon{width:48px;height:48px;background:rgba(16,185,129,.12);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:18px;color:#10b981;margin-bottom:16px}
.workflow-card h3{font-size:16px;font-weight:600;margin-bottom:8px}
.workflow-card p{font-size:13px;color:#9ca3b8;line-height:1.6;margin-bottom:14px}
.tag-row{display:flex;flex-wrap:wrap;gap:6px}
.tag{font-size:11px;color:#10b981;background:rgba(16,185,129,.1);border:1px solid rgba(16,185,129,.2);padding:3px 9px;border-radius:20px}

/* Story */
.story-card{background:#161a23;border:1px solid #262d3d;border-radius:16px;padding:48px;max-width:760px;margin:0 auto}
.story-card h2{font-size:24px;font-weight:700;margin-bottom:36px;text-align:center}
.story-item{padding-left:28px;position:relative;margin-bottom:28px}
.story-item::before{content:'';position:absolute;left:0;top:6px;width:10px;height:10px;background:#10b981;border-radius:50%}
.story-item::after{content:'';position:absolute;left:4px;top:20px;width:2px;height:calc(100% + 10px);background:#262d3d}
.story-item:last-child::after{display:none}
.story-item h4{font-size:16px;font-weight:600;margin-bottom:6px}
.story-item p{font-size:14px;color:#9ca3b8;line-height:1.7;margin:0}

/* Audience */
.audience-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px;max-width:820px;margin:0 auto}
.audience-card{background:#161a23;border:1px solid #262d3d;border-radius:14px;padding:36px}
.audience-card h3{font-size:18px;font-weight:600;margin-bottom:10px}
.audience-card>p{font-size:14px;color:#9ca3b8;line-height:1.6;margin-bottom:20px}
.check-list{list-style:none;padding:0;margin:0}
.check-list li{display:flex;align-items:center;gap:10px;font-size:14px;color:#9ca3b8;margin-bottom:8px}
.check-list li::before{content:'✓';color:#10b981;font-weight:700;flex-shrink:0}

/* CTA */
.cta-section{padding:80px 0}
.cta-card{background:linear-gradient(135deg,rgba(16,185,129,.15),rgba(5,150,105,.08));border:1px solid rgba(16,185,129,.25);border-radius:20px;padding:64px 48px;text-align:center}
.cta-card h2{font-size:32px;font-weight:700;margin-bottom:14px}
.cta-card p{font-size:16px;color:#9ca3b8;margin-bottom:32px}
.btn-green{background:#10b981;color:#fff;padding:14px 30px;border-radius:10px;font-weight:600;font-size:15px;display:inline-block;transition:background .2s;margin:6px}
.btn-green:hover{background:#059669;color:#fff}
.btn-outline{background:transparent;color:#9ca3b8;padding:14px 30px;border-radius:10px;font-weight:500;font-size:15px;display:inline-block;border:1px solid #313a4d;transition:all .2s;margin:6px}
.btn-outline:hover{color:#e8eaf0;border-color:#10b981}

@media(max-width:900px){.workflow-grid{grid-template-columns:1fr 1fr}}
@media(max-width:640px){
  .workflow-grid,.stats-grid,.audience-grid{grid-template-columns:1fr}
  .about-hero h1{font-size:32px}
  .story-card,.cta-card{padding:32px 24px}
}
</style>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<!-- Hero -->
<section class="about-hero">
  <div class="container">
    <h1>Meet <span>Ovi</span> — Your Top 1% AI QA</h1>
    <p class="lead">The AI that tests like a human. Hire and onboard in under 10 minutes, connect to GitHub and Linear, and Ovi immediately starts doing the work of a senior QA engineer.</p>
  </div>
</section>

<!-- Mission -->
<section class="section" style="padding-top:0">
  <div class="container">
    <div class="mission-card">
      <span class="section-label">Our Mission</span>
      <h2>Every engineering team deserves a great QA engineer</h2>
      <p>Most startups skip QA because it's expensive, slow, and hard to hire for. We built Ovi to change that. An AI that thinks like a QA engineer — available instantly, onboards in minutes, and ships with your team from day one.</p>
    </div>
  </div>
</section>

<!-- Stats -->
<section class="section">
  <div class="container">
    <div class="text-center" style="margin-bottom:48px">
      <span class="section-label">The Reality</span>
      <h2 class="section-title">Most bugs don't need to exist</h2>
    </div>
    <div class="stats-grid">
      <div class="stat-card">
        <span class="stat-number">70%</span>
        <span class="stat-label">of bugs come from misalignment between what was expected and what was built</span>
      </div>
      <div class="stat-card">
        <span class="stat-number">10x</span>
        <span class="stat-label">more expensive to fix bugs after they reach production vs. catching them pre-merge</span>
      </div>
      <div class="stat-card">
        <span class="stat-number">35%</span>
        <span class="stat-label">of sprint capacity lost to rework and bug-fixing cycles without QA coverage</span>
      </div>
    </div>
  </div>
</section>

<!-- How Ovi Works -->
<section class="section">
  <div class="container">
    <div class="text-center" style="margin-bottom:48px">
      <span class="section-label">What Ovi Does</span>
      <h2 class="section-title">Full e2e QA — automated</h2>
      <p class="section-sub">Ovi covers the entire QA workflow, from ticket to release.</p>
    </div>
    <div class="workflow-grid">
      <div class="workflow-card">
        <div class="workflow-icon"><i class="fas fa-ticket-alt"></i></div>
        <h3>Ticket Analysis</h3>
        <p>Ovi reviews tickets before coding starts — surfacing gaps, edge cases, and QA questions before a line is written.</p>
        <div class="tag-row"><span class="tag">Edge cases</span><span class="tag">QA questions</span><span class="tag">Risk flags</span></div>
      </div>
      <div class="workflow-card">
        <div class="workflow-icon"><i class="fas fa-code-pull-request"></i></div>
        <h3>PR Analysis</h3>
        <p>Every PR analyzed for functional bugs, logic errors, edge cases, and UI/UX risks. Ship score and blockers clearly separated.</p>
        <div class="tag-row"><span class="tag">Bug detection</span><span class="tag">Ship score</span><span class="tag">Go/No-Go</span></div>
      </div>
      <div class="workflow-card">
        <div class="workflow-icon"><i class="fas fa-list-check"></i></div>
        <h3>Test Recipe</h3>
        <p>Prioritized test scenarios with exact steps and expected results, generated from your actual code changes.</p>
        <div class="tag-row"><span class="tag">Step-by-step</span><span class="tag">Prioritized</span><span class="tag">From code</span></div>
      </div>
      <div class="workflow-card">
        <div class="workflow-icon"><i class="fas fa-globe"></i></div>
        <h3>Browser Testing</h3>
        <p>Ovi runs every test scenario in a real cloud Chromium browser, captures screenshots, and posts a pass/fail report.</p>
        <div class="tag-row"><span class="tag">Real browser</span><span class="tag">Screenshots</span><span class="tag">5–15 min</span></div>
      </div>
      <div class="workflow-card">
        <div class="workflow-icon"><i class="fas fa-code"></i></div>
        <h3>Playwright Code</h3>
        <p>Downloadable <code>.spec.js</code> files with accurate selectors extracted from your codebase. Drop into CI and run.</p>
        <div class="tag-row"><span class="tag">Ready-to-use</span><span class="tag">Real selectors</span><span class="tag">CI-ready</span></div>
      </div>
      <div class="workflow-card">
        <div class="workflow-icon"><i class="fas fa-flag-checkered"></i></div>
        <h3>Release Report</h3>
        <p>A clear summary posted to your PR — blockers, non-blockers, and a final Go/No-Go so the team always knows where they stand.</p>
        <div class="tag-row"><span class="tag">Go/No-Go</span><span class="tag">Blockers flagged</span><span class="tag">On GitHub</span></div>
      </div>
    </div>
  </div>
</section>

<!-- Story -->
<section class="section">
  <div class="container">
    <div class="story-card">
      <h2>Why We Built Ovi</h2>
      <div class="story-item">
        <h4>The Problem We Lived</h4>
        <p>Engineer thinks it works one way. PM expected another. QA finds out at the end. The result? Bugs that shouldn't exist, endless back-and-forth, and rework that kills velocity and morale.</p>
      </div>
      <div class="story-item">
        <h4>Testing After Is Too Late</h4>
        <p>The traditional approach — build first, test later — doesn't work for small teams. By the time issues surface, code is merged and context is lost. Fixing becomes expensive.</p>
      </div>
      <div class="story-item">
        <h4>Most Teams Can't Afford a QA Engineer</h4>
        <p>A great QA engineer costs $80–120k/yr. Most startups either skip QA entirely or hire one person who gets buried. Neither works. The gap between "we test manually" and "we have a real QA process" is huge.</p>
      </div>
      <div class="story-item">
        <h4>The Result: Ovi</h4>
        <p>Ovi gives every team the QA engineer they always wanted — one that onboards in minutes, never sleeps, reviews every change, and gets smarter with every codebase it learns.</p>
      </div>
    </div>
  </div>
</section>

<!-- Who We Help -->
<section class="section">
  <div class="container">
    <div class="text-center" style="margin-bottom:48px">
      <span class="section-label">Who We Help</span>
      <h2 class="section-title">Built for teams that move fast</h2>
    </div>
    <div class="audience-grid">
      <div class="audience-card">
        <h3>Early-Stage Startups</h3>
        <p>Moving fast with a small team. No QA budget. Ovi gives you AI-powered quality from day one — your first QA hire, without the headcount.</p>
        <ul class="check-list">
          <li>Ship with confidence on every PR</li>
          <li>Catch bugs before your users do</li>
          <li>Clear test scenarios for every change</li>
        </ul>
      </div>
      <div class="audience-card">
        <h3>Scaling Teams</h3>
        <p>Growing fast but quality is slipping. Bug-fixing cycles are eating your sprints. Ovi breaks the cycle and scales quality with you.</p>
        <ul class="check-list">
          <li>Reduce rework and back-and-forth</li>
          <li>Consistent QA coverage across all PRs</li>
          <li>Browser tests on every significant change</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-section">
  <div class="container">
    <div class="cta-card">
      <h2>The QA every engineer always wanted.</h2>
      <p>Hire Ovi today. Set up in under 10 minutes.</p>
      <a href="/" class="btn-green">Get Early Access</a>
      <a href="https://calendar.app.google/wsDJhHMutNzMZQhu6" class="btn-outline" target="_blank">Book a Demo</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
