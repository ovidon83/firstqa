<%- include('partials/header', { title: 'How FirstQA Works – Hire Ovi in Under 10 Minutes' }) %>
<style>
body{background:#0f1117;color:#e8eaf0;font-family:'Inter',-apple-system,system-ui,sans-serif}
a{color:#10b981;text-decoration:none}
a:hover{color:#059669}
code{font-family:'JetBrains Mono','SF Mono',monospace;background:rgba(16,185,129,.1);color:#10b981;padding:2px 8px;border-radius:5px;font-size:.88em}
.container{max-width:900px;margin:0 auto;padding:0 24px}

.page-hero{padding:80px 0 64px;text-align:center}
.page-hero h1{font-size:40px;font-weight:700;margin-bottom:16px;letter-spacing:-.02em}
.page-hero h1 span{background:linear-gradient(135deg,#10b981,#059669);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.page-hero p{font-size:16px;color:#9ca3b8;max-width:560px;margin:0 auto;line-height:1.7}

/* Steps */
.steps-section{padding:0 0 80px}
.step{display:grid;grid-template-columns:80px 1fr;gap:32px;margin-bottom:16px}
.step-num{width:56px;height:56px;border-radius:50%;background:rgba(16,185,129,.12);border:2px solid rgba(16,185,129,.3);display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:700;color:#10b981;flex-shrink:0;margin-top:4px}
.step-body{background:#161a23;border:1px solid #262d3d;border-radius:14px;padding:28px 32px}
.step-body h2{font-size:19px;font-weight:700;margin-bottom:10px}
.step-body p{font-size:14px;color:#9ca3b8;line-height:1.8;margin:0}
.step-connector{width:2px;height:24px;background:#262d3d;margin-left:27px;margin-bottom:16px}
.step-tag{display:inline-block;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.6px;color:#10b981;background:rgba(16,185,129,.1);border:1px solid rgba(16,185,129,.2);padding:3px 10px;border-radius:20px;margin-bottom:10px}

/* What happens next */
.flow-section{padding:0 0 80px}
.flow-title{font-size:26px;font-weight:700;margin-bottom:40px;text-align:center}
.flow-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:32px}
.flow-card{background:#161a23;border:1px solid #262d3d;border-radius:12px;padding:24px}
.flow-card .fc-icon{font-size:20px;margin-bottom:12px}
.flow-card h3{font-size:15px;font-weight:600;margin-bottom:8px}
.flow-card p{font-size:13px;color:#9ca3b8;line-height:1.6;margin:0}
.flow-card code{font-size:.82em}

/* CTA */
.cta-wrap{background:#161a23;border:1px solid #313a4d;border-radius:16px;padding:48px;text-align:center}
.cta-wrap h2{font-size:26px;font-weight:700;margin-bottom:12px}
.cta-wrap p{font-size:15px;color:#9ca3b8;margin-bottom:28px}
.btn-primary{display:inline-flex;align-items:center;gap:8px;background:#10b981;color:#fff;font-size:14px;font-weight:600;padding:13px 24px;border-radius:10px;text-decoration:none;transition:background .2s;margin:4px}
.btn-primary:hover{background:#059669;color:#fff}
.btn-outline{display:inline-flex;align-items:center;gap:8px;background:transparent;color:#9ca3b8;font-size:14px;font-weight:500;padding:13px 24px;border-radius:10px;text-decoration:none;border:1px solid #313a4d;transition:all .2s;margin:4px}
.btn-outline:hover{color:#e8eaf0;border-color:#10b981}

@media(max-width:640px){
  .step{grid-template-columns:1fr}
  .step-num{display:none}
  .flow-grid{grid-template-columns:1fr}
  .page-hero h1{font-size:28px}
}
</style>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<div class="page-hero">
  <div class="container">
    <h1>Up and running in <span>under 10 minutes</span></h1>
    <p>No engineers needed. No CI changes. Ovi works where your team already works.</p>
  </div>
</div>

<div class="container">

  <!-- Steps -->
  <div class="steps-section">

    <div class="step">
      <div class="step-num">1</div>
      <div class="step-body">
        <span class="step-tag">Hire Ovi</span>
        <h2>Create your FirstQA account</h2>
        <p>Sign up at <a href="https://firstqa.dev">firstqa.dev</a> in 30 seconds. No credit card required for the trial. Choose early access or apply for the Launch Partner program (limited to 20 spots).</p>
      </div>
    </div>
    <div class="step-connector"></div>

    <div class="step">
      <div class="step-num">2</div>
      <div class="step-body">
        <span class="step-tag">Onboard Ovi</span>
        <h2>Connect GitHub and Linear</h2>
        <p>Install the FirstQA GitHub App on your repositories with one click. Connect Linear for ticket analysis. Ovi indexes your codebase, reads your existing tickets, and learns your product — like any new hire would on their first day.</p>
      </div>
    </div>
    <div class="step-connector"></div>

    <div class="step">
      <div class="step-num">3</div>
      <div class="step-body">
        <span class="step-tag">Ovi Gets to Work</span>
        <h2>Ovi starts from day one</h2>
        <p>From the moment you connect, Ovi reviews every new PR and ticket automatically. Trigger a full test run anytime by commenting <code>/qa</code> on a PR — analysis, browser tests, Playwright code, and a report, posted right where your team works.</p>
      </div>
    </div>

  </div>

  <!-- What happens on every PR -->
  <div class="flow-section">
    <div class="flow-title">What happens on every PR</div>
    <div class="flow-grid">
      <div class="flow-card">
        <div class="fc-icon">🎫</div>
        <h3>Ticket Analysis</h3>
        <p>Ovi reviews your Linear/Jira ticket and posts QA questions and edge cases before coding starts.</p>
      </div>
      <div class="flow-card">
        <div class="fc-icon">🔍</div>
        <h3>PR Analysis</h3>
        <p>On every PR open or update, Ovi analyzes the diff for bugs, risks, and missing test coverage.</p>
      </div>
      <div class="flow-card">
        <div class="fc-icon">📋</div>
        <h3>Test Recipe</h3>
        <p>Prioritized test scenarios with exact steps and expected results, generated from your code changes.</p>
      </div>
      <div class="flow-card">
        <div class="fc-icon">🌐</div>
        <h3>Browser Testing</h3>
        <p>Comment <code>/qa testrun</code> and Ovi runs every scenario in a real cloud browser. Screenshots included.</p>
      </div>
      <div class="flow-card">
        <div class="fc-icon">⚙️</div>
        <h3>Playwright Code</h3>
        <p>Ready-to-use <code>.spec.js</code> files with accurate selectors from your codebase. Drop into CI.</p>
      </div>
      <div class="flow-card">
        <div class="fc-icon">🚦</div>
        <h3>Go / No-Go</h3>
        <p>A clear release decision with blockers and non-blockers separated. Your team always knows where they stand.</p>
      </div>
    </div>
  </div>

  <!-- CTA -->
  <div class="cta-wrap" style="margin-bottom:80px">
    <h2>Ready to hire Ovi?</h2>
    <p>Set up in under 10 minutes. Works on your first PR, same day.</p>
    <a href="https://github.com/apps/oviai-by-firstqa/installations/new" class="btn-primary" target="_blank"><i class="fab fa-github"></i> Install GitHub App</a>
    <a href="/docs" class="btn-outline"><i class="fas fa-book"></i> Read the Docs</a>
  </div>

</div>

<%- include('partials/footer') %>
