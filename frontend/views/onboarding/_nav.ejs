<nav class="navbar">
  <div class="container">
    <a href="/dashboard" class="logo">
      <img src="/logo/firstqa-logo-mark.svg" alt="" class="logo-mark" width="28" height="28">
      <span>FirstQA</span>
    </a>
    <div class="progress-bar" role="progressbar">
      <% for (var i = 1; i <= 6; i++) { %>
        <span class="progress-step <%= i <= (typeof progress !== 'undefined' ? progress : 1) ? 'active' : '' %>"></span>
      <% } %>
    </div>
  </div>
</nav>
